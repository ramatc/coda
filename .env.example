# Coda — Fase 0 environment template.
# Copy to .env and fill in local values. No cloud-provider credentials belong here.

# Runtime
NODE_ENV=development

# App URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# Database (local docker-compose Postgres — see docker-compose.yml in PR2)
DATABASE_URL=postgresql://coda:coda@localhost:5432/coda?schema=public
DIRECT_URL=postgresql://coda:coda@localhost:5432/coda?schema=public

# Redis (local docker-compose Redis — see docker-compose.yml in PR2)
REDIS_URL=redis://localhost:6379

# Clerk (auth — wired in PR4; use your Clerk dev instance keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
