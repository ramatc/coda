// Coda — Fase 0 core schema.
// Prisma 7 requires an explicit generator `output`. No preview features and no
// datasource extensions: pgvector / embeddings are deferred to Fase 3.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum ListenSource {
  MANUAL
  SPOTIFY_SYNC
  LASTFM_SYNC
  APPLE_MUSIC_SYNC

  @@map("listen_source")
}

enum AlbumArtistRole {
  PRIMARY
  FEATURED
  PRODUCER
  COMPOSER

  @@map("album_artist_role")
}

enum ActivityType {
  LISTEN
  RATING
  REVIEW

  @@map("activity_type")
}

enum RecommendationStatus {
  ACTIVE
  DISMISSED
  CONSUMED

  @@map("recommendation_status")
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  clerkUserId String   @unique @map("clerk_user_id")
  email       String   @unique
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  profile          Profile?
  listens          Listen[]
  ratings          Rating[]
  reviews          Review[]
  lists            List[]
  following        Follow[]              @relation("Follower")
  followers        Follow[]              @relation("Following")
  genrePreferences UserGenrePreference[]
  artistFavorites  UserArtistFavorite[]
  albumFavorites   UserAlbumFavorite[]
  activityEvents   ActivityEvent[]
  recommendations  Recommendation[]

  @@map("users")
}

model Profile {
  userId      String  @id @map("user_id") @db.Uuid
  // Canonicalized to lowercase by both the Clerk webhook sync
  // (clerk-webhook.service.ts) and the profile-edit flow (profile.service.ts)
  // so "Admin"/"admin"/"ADMIN" cannot become distinct `/u/[username]` profiles.
  // Open question (Fase 1, PR3 round 3): there is no backfill migration for
  // pre-existing mixed-case rows, because as of this PR the `profiles` table
  // has never held real data outside tests (no seed script, no live/shared
  // DB in this sandbox — verified by the absence of any `prisma/seed*` file
  // and the fact PR2 only ever wrote the un-normalized Clerk-id fallback). If
  // this migration set is ever applied to a non-empty `profiles` table with
  // pre-existing mixed-case usernames, add a one-off migration that runs
  // `UPDATE profiles SET username = LOWER(username) WHERE username != LOWER(username)`,
  // guarded to skip/report rows that would collide with an existing lowercase
  // username rather than silently merging them.
  username    String  @unique
  displayName String  @map("display_name")
  bio         String? @db.Text
  avatarUrl   String? @map("avatar_url")
  bannerUrl   String? @map("banner_url")
  isPrivate   Boolean @default(false) @map("is_private")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Genre {
  id            String  @id @default(uuid()) @db.Uuid
  slug          String  @unique
  name          String
  parentGenreId String? @map("parent_genre_id") @db.Uuid

  parent          Genre?                @relation("GenreHierarchy", fields: [parentGenreId], references: [id])
  children        Genre[]               @relation("GenreHierarchy")
  albums          AlbumGenre[]
  userPreferences UserGenrePreference[]

  @@index([parentGenreId])
  @@map("genres")
}

model Artist {
  id        String   @id @default(uuid()) @db.Uuid
  mbid      String?  @unique
  spotifyId String?  @unique @map("spotify_id")
  name      String
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  albums        Album[]              @relation("PrimaryArtist")
  albumArtists  AlbumArtist[]
  userFavorites UserArtistFavorite[]

  @@index([name])
  @@map("artists")
}

model Album {
  id              String    @id @default(uuid()) @db.Uuid
  mbid            String?   @unique
  spotifyId       String?   @unique @map("spotify_id")
  title           String
  releaseDate     DateTime? @map("release_date") @db.Date
  coverUrl        String?   @map("cover_url")
  primaryArtistId String    @map("primary_artist_id") @db.Uuid
  trackCount      Int?      @map("track_count")
  popularityScore Float     @default(0) @map("popularity_score")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  primaryArtist   Artist              @relation("PrimaryArtist", fields: [primaryArtistId], references: [id])
  artists         AlbumArtist[]
  genres          AlbumGenre[]
  tracks          Track[]
  listens         Listen[]
  ratings         Rating[]
  reviews         Review[]
  listItems       ListItem[]
  userFavorites   UserAlbumFavorite[]
  activityEvents  ActivityEvent[]
  recommendations Recommendation[]

  @@index([releaseDate])
  @@index([popularityScore(sort: Desc)])
  @@index([primaryArtistId])
  @@map("albums")
}

model Track {
  id         String @id @default(uuid()) @db.Uuid
  albumId    String @map("album_id") @db.Uuid
  position   Int
  title      String
  durationMs Int?   @map("duration_ms")

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([albumId, position])
  @@index([albumId])
  @@map("tracks")
}

model AlbumArtist {
  albumId  String          @map("album_id") @db.Uuid
  artistId String          @map("artist_id") @db.Uuid
  role     AlbumArtistRole

  album  Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([albumId, artistId, role])
  @@index([artistId])
  @@map("album_artists")
}

model AlbumGenre {
  albumId String @map("album_id") @db.Uuid
  genreId String @map("genre_id") @db.Uuid
  weight  Float  @default(1)

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([albumId, genreId])
  @@index([genreId])
  @@map("album_genres")
}

model Listen {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  albumId    String       @map("album_id") @db.Uuid
  listenedAt DateTime     @default(now()) @map("listened_at")
  source     ListenSource @default(MANUAL)
  note       String?      @db.Text

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  album          Album           @relation(fields: [albumId], references: [id])
  activityEvents ActivityEvent[]

  @@index([userId, listenedAt(sort: Desc)])
  @@index([albumId])
  @@map("listens")
}

model Rating {
  id        String   @unique @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  albumId   String   @map("album_id") @db.Uuid
  score     Int // 1-10
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  album          Album           @relation(fields: [albumId], references: [id])
  review         Review?
  activityEvents ActivityEvent[]

  @@id([userId, albumId])
  @@index([albumId, score(sort: Desc)])
  @@map("ratings")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  albumId   String   @map("album_id") @db.Uuid
  body      String   @db.Text
  isSpoiler Boolean  @default(false) @map("is_spoiler")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  album          Album           @relation(fields: [albumId], references: [id])
  rating         Rating          @relation(fields: [userId, albumId], references: [userId, albumId])
  activityEvents ActivityEvent[]

  @@unique([userId, albumId])
  @@index([albumId, createdAt(sort: Desc)])
  @@map("reviews")
}

model List {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String
  description String?  @db.Text
  isRanked    Boolean  @default(false) @map("is_ranked")
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ListItem[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("lists")
}

model ListItem {
  id       String  @id @default(uuid()) @db.Uuid
  listId   String  @map("list_id") @db.Uuid
  albumId  String  @map("album_id") @db.Uuid
  position Int
  note     String? @db.Text

  list  List  @relation(fields: [listId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id])

  @@unique([listId, albumId])
  @@index([listId, position])
  @@map("list_items")
}

model Follow {
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

// Onboarding preference: genres a user selected during onboarding, weighted for
// recommendation scoring.
model UserGenrePreference {
  userId    String   @map("user_id") @db.Uuid
  genreId   String   @map("genre_id") @db.Uuid
  weight    Float    @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([userId, genreId])
  @@index([genreId])
  @@map("user_genre_preferences")
}

// Onboarding preference: favorite artists a user selected, optionally ranked.
model UserArtistFavorite {
  userId    String   @map("user_id") @db.Uuid
  artistId  String   @map("artist_id") @db.Uuid
  rank      Int?
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([userId, artistId])
  @@index([artistId])
  @@map("user_artist_favorites")
}

// Onboarding preference: favorite albums a user selected, optionally ranked.
model UserAlbumFavorite {
  userId    String   @map("user_id") @db.Uuid
  albumId   String   @map("album_id") @db.Uuid
  rank      Int?
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@id([userId, albumId])
  @@index([albumId])
  @@map("user_album_favorites")
}

// Denormalized activity row powering the own-activity stream (GET /me/activity)
// and, in Fase 2, the social feed. `rating` is a nullable scalar FK to
// Rating.id (SetNull on delete), symmetric with the `listenId`/`reviewId`
// pattern — the composite (userId, albumId) FK was unconditional and broke
// every LISTEN-type insert, so app-layer cleanup is required on delete
// instead of a DB-level cascade.
model ActivityEvent {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  type       ActivityType
  albumId    String       @map("album_id") @db.Uuid
  listenId   String?      @map("listen_id") @db.Uuid
  reviewId   String?      @map("review_id") @db.Uuid
  ratingId   String?      @map("rating_id") @db.Uuid
  payload    Json? // score snapshot etc. for render without joins
  occurredAt DateTime     @default(now()) @map("occurred_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  album  Album   @relation(fields: [albumId], references: [id])
  listen Listen? @relation(fields: [listenId], references: [id], onDelete: SetNull)
  review Review? @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  rating Rating? @relation(fields: [ratingId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt(sort: Desc), id(sort: Desc)])
  @@index([occurredAt(sort: Desc)])
  @@index([albumId])
  @@index([listenId])
  @@index([reviewId])
  @@index([ratingId])
  @@map("activity_events")
}

// Precomputed heuristic recommendation surfaced on /home. Rebuildable, derived
// from onboarding preferences + tracking activity.
model Recommendation {
  id          String               @id @default(uuid()) @db.Uuid
  userId      String               @map("user_id") @db.Uuid
  albumId     String               @map("album_id") @db.Uuid
  score       Float
  reason      Json? // {topGenre, matchedArtist, ...}
  status      RecommendationStatus @default(ACTIVE)
  generatedAt DateTime             @default(now()) @map("generated_at")
  dismissedAt DateTime?            @map("dismissed_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId, status, score(sort: Desc)])
  @@map("recommendations")
}
